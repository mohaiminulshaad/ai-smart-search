{
  "name": "shopify-smart-search",
  "version": "2.0.0",
  "description": "Shopify Smart Search App — AI-powered product search with RAG and vector embeddings",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -n \"SERVER,VITE\" -c \"cyan,magenta\" --kill-others-on-fail \"node server.js\" \"vite --config dashboard/vite.config.ts\"",
    "dev:watch": "concurrently -n \"SERVER,VITE\" -c \"cyan,magenta\" --kill-others-on-fail \"node --watch server.js\" \"vite --config dashboard/vite.config.ts\"",
    "dev:server": "node --watch server.js",
    "dev:vite": "vite --config dashboard/vite.config.ts",
    "build": "vite build --config dashboard/vite.config.ts",
    "build:widget": "cross-env NODE_ENV=production vite build --config widget/vite.widget.config.ts",
    "init-db": "node scripts/init-db.js",
    "migrate-chat": "node scripts/migrate-chat-tables.js",
    "migrate-dashboard": "node scripts/migrate-dashboard.js",
    "check-db": "node scripts/check-db.js",
    "clear-db": "node scripts/clear-db.js"
  },
  "keywords": [
    "shopify",
    "oauth",
    "ecommerce"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@langchain/openai": "^1.2.8",
    "@langchain/qdrant": "^1.0.1",
    "@langchain/textsplitters": "^1.0.1",
    "@qdrant/qdrant-js": "^1.17.0",
    "axios": "^1.6.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "cryptr": "^6.3.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.25",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "openai": "^6.22.0",
    "pg": "^8.11.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^7.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
