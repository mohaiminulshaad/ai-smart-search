# Shopify App Credentials (from Partners Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
VITE_SHOPIFY_API_KEY=your_api_key_here

# OAuth scopes
SCOPES=read_files,write_files,read_inventory,read_orders,read_products,write_products,read_script_tags,write_script_tags

# Server Configuration
HOST=https://your-ngrok-url.ngrok-free.app
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://postgres:1234@localhost:5432/smart_search_app

# Security
ENCRYPTION_KEY=generate_a_random_32_character_string_here

# Gemini API Key (used for embeddings vision description)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (used for vector embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
