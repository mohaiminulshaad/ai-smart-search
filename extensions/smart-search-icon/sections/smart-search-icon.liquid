{% comment %} Smart Search Icon - Main Section {% endcomment %}

{%- style -%}
  .smart-search-section-{{ section.id }} {
    --ss-icon-color: {{ section.settings.icon_color }};
    --ss-icon-size: {{ section.settings.icon_size }}px;
  }
{%- endstyle -%}

{%- if section.settings.enable_search_icon -%}
  <div class="smart-search-section-{{ section.id }}" {{ section.shopify_attributes }}>
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'icon' -%}
          {% render 'smart-search-icon-block', block: block %}
      {%- endcase -%}
    {%- endfor -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Smart Search Icon",
  "description": "Add a search icon that opens a product search popup",
  "max_blocks": 1,
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_search_icon",
      "default": true,
      "label": "Enable search icon"
    },
    {
      "type": "text",
      "id": "label",
      "default": "Search",
      "label": "Button label"
    },
    {
      "type": "color",
      "id": "icon_color",
      "default": "#6366f1",
      "label": "Icon color"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "default": 24,
      "label": "Icon size (px)"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "Custom icon (optional)"
    }
  ],
  "blocks": [
    {
      "type": "icon",
      "name": "Search Icon",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "default": "Search",
          "label": "Button label"
        },
        {
          "type": "color",
          "id": "icon_color",
          "default": "#6366f1",
          "label": "Icon color"
        },
        {
          "type": "range",
          "id": "icon_size",
          "min": 16,
          "max": 48,
          "step": 2,
          "default": 24,
          "label": "Icon size (px)"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom icon (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Smart Search Icon",
      "blocks": [
        {
          "type": "icon"
        }
      ]
    }
  ]
}
{% endschema %}
