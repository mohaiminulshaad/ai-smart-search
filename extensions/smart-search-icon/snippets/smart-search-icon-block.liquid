{% comment %} Smart Search Icon Block Snippet {% endcomment %}

{%- assign icon_color = block.settings.icon_color | default: section.settings.icon_color | default: '#6366f1' -%}
{%- assign icon_size = block.settings.icon_size | default: section.settings.icon_size | default: 24 -%}
{%- assign label = block.settings.label | default: 'Open search' -%}

<div 
  class="smart-search-icon-wrapper" 
  data-shop="{{ request.host }}"
  data-app-origin="{{ routes.root_url }}"
  data-color="{{ icon_color }}"
  data-icon-size="{{ icon_size }}"
  data-smart-search-section
  style="
    --ss-icon-color: {{ icon_color }};
    --ss-icon-size: {{ icon_size }}px;
  "
>
  <button 
    class="smart-search-trigger" 
    aria-label="{{ label }}"
    type="button"
  >
    {%- if block.settings.custom_icon != blank -%}
      <img src="{{ block.settings.custom_icon | image_url }}" alt="Search" class="custom-icon" width="{{ icon_size }}" height="{{ icon_size }}" />
    {%- else -%}
      <svg width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    {%- endif -%}
  </button>
</div>

<style>
  .smart-search-icon-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  
  .smart-search-trigger {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--ss-icon-color);
    transition: transform 0.2s ease, opacity 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .smart-search-trigger:hover {
    transform: scale(1.1);
    opacity: 0.8;
  }
  
  .smart-search-trigger svg {
    width: var(--ss-icon-size);
    height: var(--ss-icon-size);
  }
  
  .custom-icon {
    width: var(--ss-icon-size);
    height: var(--ss-icon-size);
    object-fit: contain;
  }
  
  /* Search Popup Modal */
  .smart-search-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: 99999;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 80px;
    animation: ss-fade-in 0.15s ease;
  }
  
  .smart-search-modal-overlay.active {
    display: flex;
  }
  
  .smart-search-modal {
    background: #fff;
    border-radius: 18px;
    width: 100%;
    max-width: 560px;
    margin: 0 16px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.22);
    animation: ss-slide-down 0.18s ease;
    overflow: hidden;
  }
  
  .smart-search-modal-header {
    background: linear-gradient(135deg, var(--ss-icon-color), color-mix(in srgb, var(--ss-icon-color) 80%, black));
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: #fff;
  }
  
  .smart-search-modal-header svg {
    flex-shrink: 0;
  }
  
  .smart-search-modal-title {
    flex: 1;
    font-weight: 700;
    font-size: 15px;
  }
  
  .smart-search-modal-close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    font-size: 20px;
    cursor: pointer;
    padding: 2px 4px;
    border-radius: 6px;
    line-height: 1;
  }
  
  .smart-search-modal-close:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  
  .smart-search-input-wrapper {
    padding: 14px 16px 10px;
  }
  
  .smart-search-input-container {
    display: flex;
    align-items: center;
    gap: 10px;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
    padding: 11px 14px;
    background: #fafafa;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  
  .smart-search-input-container:focus-within {
    border-color: var(--ss-icon-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ss-icon-color) 10%, transparent);
  }
  
  .smart-search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    font-size: 15px;
    color: #111827;
  }
  
  .smart-search-input::placeholder {
    color: #9ca3af;
  }
  
  .smart-search-results {
    max-height: 360px;
    overflow-y: auto;
    padding: 0 12px 12px;
  }
  
  .smart-search-result-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 8px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.12s;
    text-decoration: none;
    color: inherit;
  }
  
  .smart-search-result-item:hover {
    background: #f8fafc;
  }
  
  .smart-search-result-image {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: #f1f5f9;
    border: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  
  .smart-search-result-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .smart-search-result-info {
    flex: 1;
    min-width: 0;
  }
  
  .smart-search-result-title {
    font-size: 13.5px;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .smart-search-result-price {
    font-size: 13px;
    font-weight: 700;
    color: var(--ss-icon-color);
    margin-top: 3px;
  }
  
  .smart-search-result-stock {
    font-size: 11px;
    font-weight: 500;
    color: #16a34a;
  }
  
  .smart-search-result-stock.out-of-stock {
    color: #dc2626;
  }
  
  .smart-search-empty {
    text-align: center;
    padding: 28px 0;
    color: #9ca3af;
    font-size: 14px;
  }
  
  .smart-search-footer {
    padding: 8px 18px;
    border-top: 1px solid #f1f5f9;
    background: #fafafa;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
    color: #9ca3af;
  }
  
  .smart-search-footer kbd {
    background: #e5e7eb;
    border-radius: 4px;
    padding: 1px 5px;
    font-size: 10px;
    font-family: inherit;
  }
  
  @keyframes ss-fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes ss-slide-down {
    from { opacity: 0; transform: translateY(-12px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  
  @keyframes ss-spin {
    to { transform: rotate(360deg); }
  }
  
  .smart-search-loading {
    animation: ss-spin 0.8s linear infinite;
  }
</style>

<script>
  (function() {
    // Prevent multiple instances
    if (window.__smartSearchEmbedLoaded) return;
    window.__smartSearchEmbedLoaded = true;

    const container = document.querySelector('.smart-search-icon-wrapper');
    if (!container) return;

    const shop = container.dataset.shop || window.location.host;
    const appOrigin = container.dataset.appOrigin || window.location.origin;
    const color = container.dataset.color || '#6366f1';

    // Create modal HTML
    function createModal() {
      const modal = document.createElement('div');
      modal.className = 'smart-search-modal-overlay';
      modal.id = 'smart-search-modal';
      modal.innerHTML = `
        <div class="smart-search-modal" role="dialog" aria-label="Search products">
          <div class="smart-search-modal-header">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <span class="smart-search-modal-title">Search Products</span>
            <button class="smart-search-modal-close" aria-label="Close">✕</button>
          </div>
          <div class="smart-search-input-wrapper">
            <div class="smart-search-input-container">
              <svg class="smart-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2.5" stroke-linecap="round">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input type="text" class="smart-search-input" placeholder="Search products..." />
            </div>
          </div>
          <div class="smart-search-results">
            <div class="smart-search-empty">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round" style="display: block; margin: 0 auto 10px;">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              Type to search your store
            </div>
          </div>
          <div class="smart-search-footer">
            <span>AI-powered product search</span>
            <span>Press <kbd>Esc</kbd> to close</span>
          </div>
        </div>
      `;
      document.body.appendChild(modal);
      return modal;
    }

    let modal = document.getElementById('smart-search-modal') || createModal();
    const input = modal.querySelector('.smart-search-input');
    const resultsContainer = modal.querySelector('.smart-search-results');
    const closeBtn = modal.querySelector('.smart-search-modal-close');

    let searchTimeout = null;

    // Open modal
    function openModal() {
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
      setTimeout(() => input.focus(), 100);
    }

    // Close modal
    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
      input.value = '';
      resultsContainer.innerHTML = `
        <div class="smart-search-empty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round" style="display: block; margin: 0 auto 10px;">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          Type to search your store
        </div>
      `;
    }

    // Search function
    function doSearch(query) {
      if (!query.trim()) {
        resultsContainer.innerHTML = `
          <div class="smart-search-empty">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round" style="display: block; margin: 0 auto 10px;">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            Type to search your store
          </div>
        `;
        return;
      }

      resultsContainer.innerHTML = `
        <div class="smart-search-empty">
          <svg class="smart-search-loading" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round">
            <path d="M12 2a10 10 0 1 0 4 19.1"></path>
          </svg>
        </div>
      `;

      fetch(`${appOrigin}/api/search/products`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Shop-Domain': shop,
          'ngrok-skip-browser-warning': '1'
        },
        body: JSON.stringify({ query: query, limit: 8 })
      })
      .then(r => r.json())
      .then(data => {
        const results = data.results || [];
        if (results.length === 0) {
          resultsContainer.innerHTML = `
            <div class="smart-search-empty">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e5e7eb" stroke-width="1.5" stroke-linecap="round" style="display: block; margin: 0 auto 10px;">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              No results for "${query}"
            </div>
          `;
          return;
        }

        resultsContainer.innerHTML = results.map(p => {
          const price = p.price?.min != null ? `$${(p.price.min / 100).toFixed(2)}` : '';
          return `
            <a href="/products/${p.handle}" class="smart-search-result-item">
              <div class="smart-search-result-image">
                ${p.image ? `<img src="${p.image}" alt="${p.title}" width="48" height="48" />` : '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>'}
              </div>
              <div class="smart-search-result-info">
                <div class="smart-search-result-title">${p.title}</div>
                <div style="display: flex; align-items: center; gap: 8; margin-top: 3;">
                  ${price ? `<span class="smart-search-result-price">${price}</span>` : ''}
                  <span class="smart-search-result-stock ${p.available ? '' : 'out-of-stock'}">
                    ${p.available ? '● In stock' : '● Out of stock'}
                  </span>
                </div>
              </div>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="2.5" stroke-linecap="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </a>
          `;
        }).join('');
      })
      .catch(() => {
        resultsContainer.innerHTML = `
          <div class="smart-search-empty">
            Error searching products
          </div>
        `;
      });
    }

    // Event listeners
    container.querySelector('.smart-search-trigger').addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal();
    });

    input.addEventListener('input', function(e) {
      const query = e.target.value;
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => doSearch(query), 350);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });
  })();
</script>
