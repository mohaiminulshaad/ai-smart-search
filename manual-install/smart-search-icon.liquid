{% comment %} Smart Search Icon - Add to your theme {% endcomment %}
{% comment %} Go to Theme Editor > Edit code > Add a new section {% endcomment %}

<div 
  class="smart-search-icon-section"
  data-shop="{{ request.host }}"
  data-app-origin="{{ routes.root_url }}"
  data-smart-search-section
  style="display: inline-block;"
>
  <button 
    class="smart-search-trigger" 
    aria-label="Open search"
    type="button"
    style="
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      color: #6366f1;
      display: flex;
      align-items: center;
      justify-content: center;
    "
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
  </button>

  <style>
    .smart-search-modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(4px);
      z-index: 99999;
      align-items: flex-start;
      justify-content: center;
      padding-top: 80px;
    }
    
    .smart-search-modal-overlay.active { display: flex; }
    
    .smart-search-modal {
      background: #fff;
      border-radius: 18px;
      width: 100%;
      max-width: 560px;
      margin: 0 16px;
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.22);
      overflow: hidden;
    }
    
    .smart-search-modal-header {
      background: linear-gradient(135deg, #6366f1, #4f46e5);
      padding: 14px 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: #fff;
    }
    
    .smart-search-modal-title { flex: 1; font-weight: 700; font-size: 15px; }
    
    .smart-search-modal-close {
      background: none;
      border: none;
      color: rgba(255,255,255,0.8);
      font-size: 20px;
      cursor: pointer;
      padding: 2px 4px;
    }
    
    .smart-search-input-wrap { padding: 14px 16px 10px; }
    
    .smart-search-input-container {
      display: flex;
      align-items: center;
      gap: 10px;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      padding: 11px 14px;
      background: #fafafa;
    }
    
    .smart-search-input-container:focus-within { border-color: #6366f1; }
    
    .smart-search-input {
      flex: 1;
      border: none;
      outline: none;
      background: transparent;
      font-size: 15px;
    }
    
    .smart-search-results {
      max-height: 360px;
      overflow-y: auto;
      padding: 0 12px 12px;
    }
    
    .smart-search-result {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 10px 8px;
      border-radius: 10px;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
    }
    
    .smart-search-result:hover { background: #f8fafc; }
    
    .smart-search-result-img {
      width: 48px;
      height: 48px;
      border-radius: 10px;
      background: #f1f5f9;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .smart-search-result-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 10px;
    }
    
    .smart-search-result-info { flex: 1; min-width: 0; }
    
    .smart-search-result-title {
      font-size: 13.5px;
      font-weight: 600;
      color: #111827;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    
    .smart-search-result-price {
      font-size: 13px;
      font-weight: 700;
      color: #6366f1;
      margin-top: 3px;
    }
    
    .smart-search-empty {
      text-align: center;
      padding: 28px 0;
      color: #9ca3af;
      font-size: 14px;
    }
  </style>

  <div class="smart-search-modal-overlay" id="smart-search-modal">
    <div class="smart-search-modal" role="dialog">
      <div class="smart-search-modal-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="smart-search-modal-title">Search Products</span>
        <button class="smart-search-modal-close" aria-label="Close">✕</button>
      </div>
      <div class="smart-search-input-wrap">
        <div class="smart-search-input-container">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" class="smart-search-input" placeholder="Search products..." />
        </div>
      </div>
      <div class="smart-search-results">
        <div class="smart-search-empty">Type to search your store</div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      if (window.__smartSearchSectionInit) return;
      window.__smartSearchSectionInit = true;

      var container = document.currentScript.closest('.smart-search-icon-section');
      var trigger = container.querySelector('.smart-search-trigger');
      var modal = document.getElementById('smart-search-modal');
      var input = modal.querySelector('.smart-search-input');
      var results = modal.querySelector('.smart-search-results');
      var closeBtn = modal.querySelector('.smart-search-modal-close');
      
      var shop = container.dataset.shop || window.location.host;
      var appOrigin = container.dataset.appOrigin || window.location.origin;
      
      var searchTimeout = null;

      function openModal() {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        setTimeout(function() { input.focus(); }, 100);
      }

      function closeModal() {
        modal.classList.remove('active');
        document.body.style.overflow = '';
        input.value = '';
        results.innerHTML = '<div class="smart-search-empty">Type to search your store</div>';
      }

      function doSearch(query) {
        if (!query.trim()) {
          results.innerHTML = '<div class="smart-search-empty">Type to search your store</div>';
          return;
        }

        results.innerHTML = '<div class="smart-search-empty">Searching...</div>';

        fetch(appOrigin + '/api/search/products', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Shop-Domain': shop
          },
          body: JSON.stringify({ query: query, limit: 8 })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var products = data.results || [];
          if (products.length === 0) {
            results.innerHTML = '<div class="smart-search-empty">No results for "' + query + '"</div>';
            return;
          }
          
          results.innerHTML = products.map(function(p) {
            var price = p.price && p.price.min != null ? '$' + (p.price.min / 100).toFixed(2) : '';
            return '<a href="/products/' + p.handle + '" class="smart-search-result">' +
              '<div class="smart-search-result-img">' +
                (p.image ? '<img src="' + p.image + '" alt="" />' : '') +
              '</div>' +
              '<div class="smart-search-result-info">' +
                '<div class="smart-search-result-title">' + p.title + '</div>' +
                (price ? '<div class="smart-search-result-price">' + price + '</div>' : '') +
              '</div>' +
            '</a>';
          }).join('');
        })
        .catch(function() {
          results.innerHTML = '<div class="smart-search-empty">Error searching</div>';
        });
      }

      trigger.addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
      
      input.addEventListener('input', function(e) {
        if (searchTimeout) clearTimeout(searchTimeout);
        searchTimeout = setTimeout(function() { doSearch(e.target.value); }, 350);
      });

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('active')) closeModal();
      });
    })();
  </script>
</div>
